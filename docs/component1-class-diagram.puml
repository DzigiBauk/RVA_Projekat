@startuml
title Component 1 - Command, Services, and Repositories

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false
hide empty members

package "Command Pattern" {
  interface IApplicationCommand {
    +Description : string
    +Execute() : void
    +Undo() : void
  }

  interface ICommandExecutor {
    +CanUndo : bool
    +CanRedo : bool
    +Execute(command : IApplicationCommand) : void
    +Undo() : void
    +Redo() : void
    +Clear() : void
  }

  class CommandExecutor {
    -activityLogger : IActivityLogger
    -_undoStack : Stack<IApplicationCommand>
    -_redoStack : Stack<IApplicationCommand>
    +CommandExecutor(activityLogger : IActivityLogger)
    +CanUndo : bool
    +CanRedo : bool
    +Execute(command : IApplicationCommand) : void
    +Undo() : void
    +Redo() : void
    +Clear() : void
  }

  class AddSpeciesCommand {
    -_repository : IAquaticSpeciesRepository
    -_species : AquaticSpecies
    -_before : List<AquaticSpecies>?
    -_after : List<AquaticSpecies>?
    +AddSpeciesCommand(repository : IAquaticSpeciesRepository, species : AquaticSpecies)
    +Description : string
    +Execute() : void
    +Undo() : void
    -EnsureExecuted() : void
  }

  class UpdateSpeciesCommand {
    -_repository : IAquaticSpeciesRepository
    -_updatedSpecies : AquaticSpecies
    -_before : List<AquaticSpecies>?
    -_after : List<AquaticSpecies>?
    +UpdateSpeciesCommand(repository : IAquaticSpeciesRepository, updatedSpecies : AquaticSpecies)
    +Description : string
    +Execute() : void
    +Undo() : void
    -EnsureExecuted() : void
  }

  class DeleteSpeciesCommand {
    -_speciesRepository : IAquaticSpeciesRepository
    -_readingRepository : IWaterQualityReadingRepository
    -_speciesId : Guid
    -_speciesBefore : List<AquaticSpecies>?
    -_speciesAfter : List<AquaticSpecies>?
    -_readingsBefore : List<WaterQualityReading>?
    -_readingsAfter : List<WaterQualityReading>?
    -_speciesName : string?
    +DeleteSpeciesCommand(speciesRepository : IAquaticSpeciesRepository, readingRepository : IWaterQualityReadingRepository, speciesId : Guid)
    +Description : string
    +Execute() : void
    +Undo() : void
    -EnsureExecuted() : void
  }

  class AddReadingCommand {
    -_repository : IWaterQualityReadingRepository
    -_reading : WaterQualityReading
    -_before : List<WaterQualityReading>?
    -_after : List<WaterQualityReading>?
    +AddReadingCommand(repository : IWaterQualityReadingRepository, reading : WaterQualityReading)
    +Description : string
    +Execute() : void
    +Undo() : void
    -EnsureExecuted() : void
  }

  class UpdateReadingCommand {
    -_repository : IWaterQualityReadingRepository
    -_updatedReading : WaterQualityReading
    -_before : List<WaterQualityReading>?
    -_after : List<WaterQualityReading>?
    +UpdateReadingCommand(repository : IWaterQualityReadingRepository, updatedReading : WaterQualityReading)
    +Description : string
    +Execute() : void
    +Undo() : void
    -EnsureExecuted() : void
  }

  class DeleteReadingCommand {
    -_repository : IWaterQualityReadingRepository
    -_readingId : Guid
    -_before : List<WaterQualityReading>?
    -_after : List<WaterQualityReading>?
    +DeleteReadingCommand(repository : IWaterQualityReadingRepository, readingId : Guid)
    +Description : string
    +Execute() : void
    +Undo() : void
    -EnsureExecuted() : void
  }
}

package "Repositories" {
  interface IAquaticSpeciesRepository {
    +GetAll() : IReadOnlyList<AquaticSpecies>
    +GetById(id : Guid) : AquaticSpecies?
    +Add(species : AquaticSpecies) : void
    +Update(species : AquaticSpecies) : bool
    +Remove(id : Guid) : bool
    +ReplaceAll(species : IEnumerable<AquaticSpecies>) : void
  }

  class AquaticSpeciesRepository {
    -_species : List<AquaticSpecies>
    -_syncRoot : object
    +AquaticSpeciesRepository()
    +GetAll() : IReadOnlyList<AquaticSpecies>
    +GetById(id : Guid) : AquaticSpecies?
    +Add(species : AquaticSpecies) : void
    +Update(species : AquaticSpecies) : bool
    +Remove(id : Guid) : bool
    +ReplaceAll(species : IEnumerable<AquaticSpecies>) : void
  }

  interface IWaterQualityReadingRepository {
    +GetAll() : IReadOnlyList<WaterQualityReading>
    +GetById(id : Guid) : WaterQualityReading?
    +Add(reading : WaterQualityReading) : void
    +Update(reading : WaterQualityReading) : bool
    +Remove(id : Guid) : bool
    +ReplaceAll(readings : IEnumerable<WaterQualityReading>) : void
  }

  class WaterQualityReadingRepository {
    -_readings : List<WaterQualityReading>
    -_syncRoot : object
    +WaterQualityReadingRepository()
    +GetAll() : IReadOnlyList<WaterQualityReading>
    +GetById(id : Guid) : WaterQualityReading?
    +Add(reading : WaterQualityReading) : void
    +Update(reading : WaterQualityReading) : bool
    +Remove(id : Guid) : bool
    +ReplaceAll(readings : IEnumerable<WaterQualityReading>) : void
  }
}

package "Services" {
  interface IAquariumDataService {
    +LoadAsync(filePath : string, cancellationToken : CancellationToken = default) : Task
    +SaveAsync(filePath : string, cancellationToken : CancellationToken = default) : Task
  }

  class AquariumDataService {
    -{static} SerializerOptions : JsonSerializerOptions
    -speciesRepository : IAquaticSpeciesRepository
    -readingRepository : IWaterQualityReadingRepository
    +AquariumDataService(speciesRepository : IAquaticSpeciesRepository, readingRepository : IWaterQualityReadingRepository)
    +LoadAsync(filePath : string, cancellationToken : CancellationToken = default) : Task
    +SaveAsync(filePath : string, cancellationToken : CancellationToken = default) : Task
  }

  interface IStartupDataService {
    +InitializeAsync(defaultFilePath : string, cancellationToken : CancellationToken = default) : Task
  }

  class StartupDataService {
    -{static} ClownfishId : Guid
    -{static} BettaId : Guid
    -{static} GuppyId : Guid
    -dataService : IAquariumDataService
    -speciesRepository : IAquaticSpeciesRepository
    -readingRepository : IWaterQualityReadingRepository
    -activityLogger : IActivityLogger
    +StartupDataService(dataService : IAquariumDataService, speciesRepository : IAquaticSpeciesRepository, readingRepository : IWaterQualityReadingRepository, activityLogger : IActivityLogger)
    +InitializeAsync(defaultFilePath : string, cancellationToken : CancellationToken = default) : Task
    -{static} CreateSpecies() : List<AquaticSpecies>
    -{static} CreateReadings() : List<WaterQualityReading>
  }

  interface IReadingSimulationService {
    +IsRunning : bool
    +ReadingGenerated : EventHandler<ReadingGeneratedEventArgs>?
    +Start() : void
    +Stop() : void
  }

  class ReadingSimulationService {
    -{static} AllStates : WaterQualityState[]
    -_speciesRepository : IAquaticSpeciesRepository
    -_readingRepository : IWaterQualityReadingRepository
    -_timer : DispatcherTimer
    -_visitedStatesBySpecies : Dictionary<Guid, HashSet<WaterQualityState>>
    +ReadingSimulationService(speciesRepository : IAquaticSpeciesRepository, readingRepository : IWaterQualityReadingRepository)
    +IsRunning : bool
    +ReadingGenerated : EventHandler<ReadingGeneratedEventArgs>?
    +Start() : void
    +Stop() : void
    ~SimulateOnce() : void
    -{static} GetLatestReadingOrDefault(speciesId : Guid, readings : IEnumerable<WaterQualityReading>) : WaterQualityReading
    -GetNextState(speciesId : Guid, previousState : WaterQualityState) : WaterQualityState
    -GetVisitedStates(speciesId : Guid) : HashSet<WaterQualityState>
    -{static} CreateGeneratedReading(baseline : WaterQualityReading, state : WaterQualityState) : WaterQualityReading
    -{static} Vary(value : double, maximumDelta : double, minimum : double, maximum : double) : double
    -OnTimerTick(sender : object?, e : EventArgs) : void
  }

  interface IActivityLogger {
    +Log(message : string) : void
  }

  class FileActivityLogger {
    -_syncRoot : object
    -_filePath : string
    +FileActivityLogger()
    +FileActivityLogger(filePath : string)
    +Log(message : string) : void
  }

  interface IDialogService {
    +SelectFileToOpen() : string?
    +SelectFileToSave() : string?
    +Confirm(message : string, title : string) : bool
    +ShowMessage(message : string, title : string) : void
  }

  class DialogService {
    -{static} JsonFilter : string
    +DialogService()
    +SelectFileToOpen() : string?
    +SelectFileToSave() : string?
    +Confirm(message : string, title : string) : bool
    +ShowMessage(message : string, title : string) : void
  }

  interface IAquaticSpeciesSearchService {
    +Search(species : IEnumerable<AquaticSpecies>, searchText : string?) : IReadOnlyList<AquaticSpecies>
  }

  class AquaticSpeciesSearchService {
    +AquaticSpeciesSearchService()
    +Search(species : IEnumerable<AquaticSpecies>, searchText : string?) : IReadOnlyList<AquaticSpecies>
    -{static} Contains(value : string?, term : string) : bool
  }

  interface IWaterQualityReadingSearchService {
    +Search(readings : IEnumerable<WaterQualityReading>, species : IEnumerable<AquaticSpecies>, searchText : string?) : IReadOnlyList<WaterQualityReading>
  }

  class WaterQualityReadingSearchService {
    +WaterQualityReadingSearchService()
    +Search(readings : IEnumerable<WaterQualityReading>, species : IEnumerable<AquaticSpecies>, searchText : string?) : IReadOnlyList<WaterQualityReading>
    -{static} Number(value : double) : string
    -{static} Contains(value : string?, term : string) : bool
  }
}

package "CoreWCF Service" {
  interface IAquariumService {
    +GetSpeciesAsync() : Task<List<AquaticSpecies>>
    +GetReadingsAsync(request : ReadingsRequest) : Task<List<WaterQualityReading>>
  }

  class AquariumService {
    -speciesRepository : IAquaticSpeciesRepository
    -readingRepository : IWaterQualityReadingRepository
    -activityLogger : IActivityLogger
    +AquariumService(speciesRepository : IAquaticSpeciesRepository, readingRepository : IWaterQualityReadingRepository, activityLogger : IActivityLogger)
    +GetSpeciesAsync() : Task<List<AquaticSpecies>>
    +GetReadingsAsync(request : ReadingsRequest) : Task<List<WaterQualityReading>>
    -ValidateRequest(request : ReadingsRequest?) : void
  }

  interface ICoreWcfHostService {
    +IsRunning : bool
    +Status : string
    +StatusChanged : EventHandler?
    +StartAsync(cancellationToken : CancellationToken = default) : Task
    +StopAsync(cancellationToken : CancellationToken = default) : Task
  }

  class CoreWcfHostService {
    -aquariumService : AquariumService
    -activityLogger : IActivityLogger
    -_application : WebApplication?
    +CoreWcfHostService(aquariumService : AquariumService, activityLogger : IActivityLogger)
    +IsRunning : bool
    +Status : string
    +StatusChanged : EventHandler?
    +StartAsync(cancellationToken : CancellationToken = default) : Task
    +StopAsync(cancellationToken : CancellationToken = default) : Task
    -SetStatus(status : string) : void
  }
}

package "Referenced Data Types" {
  class AquaticSpecies
  class WaterQualityReading
  class AquariumData
  class ReadingGeneratedEventArgs
  class ReadingsRequest
  enum WaterQualityState
}

CommandExecutor ..|> ICommandExecutor
CommandExecutor o-- IApplicationCommand : undo/redo stacks
CommandExecutor --> IActivityLogger

IApplicationCommand <|.. AddSpeciesCommand
IApplicationCommand <|.. UpdateSpeciesCommand
IApplicationCommand <|.. DeleteSpeciesCommand
IApplicationCommand <|.. AddReadingCommand
IApplicationCommand <|.. UpdateReadingCommand
IApplicationCommand <|.. DeleteReadingCommand

AddSpeciesCommand --> IAquaticSpeciesRepository
UpdateSpeciesCommand --> IAquaticSpeciesRepository
DeleteSpeciesCommand --> IAquaticSpeciesRepository
DeleteSpeciesCommand --> IWaterQualityReadingRepository
AddReadingCommand --> IWaterQualityReadingRepository
UpdateReadingCommand --> IWaterQualityReadingRepository
DeleteReadingCommand --> IWaterQualityReadingRepository

AquaticSpeciesRepository ..|> IAquaticSpeciesRepository
WaterQualityReadingRepository ..|> IWaterQualityReadingRepository

AquariumDataService ..|> IAquariumDataService
AquariumDataService --> IAquaticSpeciesRepository
AquariumDataService --> IWaterQualityReadingRepository
AquariumDataService --> AquariumData

StartupDataService ..|> IStartupDataService
StartupDataService --> IAquariumDataService
StartupDataService --> IAquaticSpeciesRepository
StartupDataService --> IWaterQualityReadingRepository
StartupDataService --> IActivityLogger

ReadingSimulationService ..|> IReadingSimulationService
ReadingSimulationService --> IAquaticSpeciesRepository
ReadingSimulationService --> IWaterQualityReadingRepository
ReadingSimulationService --> ReadingGeneratedEventArgs : raises

FileActivityLogger ..|> IActivityLogger
DialogService ..|> IDialogService

AquaticSpeciesSearchService ..|> IAquaticSpeciesSearchService
WaterQualityReadingSearchService ..|> IWaterQualityReadingSearchService

AquariumService ..|> IAquariumService
AquariumService --> IAquaticSpeciesRepository
AquariumService --> IWaterQualityReadingRepository
AquariumService --> IActivityLogger
AquariumService --> ReadingsRequest

CoreWcfHostService ..|> ICoreWcfHostService
CoreWcfHostService --> AquariumService : hosts
CoreWcfHostService --> IActivityLogger

AquariumData o-- AquaticSpecies
AquariumData o-- WaterQualityReading
WaterQualityReading --> WaterQualityState
ReadingGeneratedEventArgs --> WaterQualityState
ReadingsRequest --> AquaticSpecies : SpeciesId

@enduml
